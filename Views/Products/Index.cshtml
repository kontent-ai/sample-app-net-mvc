@model ProductListingViewModel

@{
    ViewData["Title"] = "Products";
}

@foreach (var block in Model.HeaderContent)
{
    @await Html.PartialAsync(block.PartialViewName, block)
}

<div class="container py-4">
    <div class="row">
        <aside class="col-lg-3 mb-4">
            @await Component.InvokeAsync("ProductFilters",
                new { categories = Model.Categories, selected = Model.SelectedCategories })
        </aside>
        <section id="product-results" class="col-lg-9">
            @await Html.PartialAsync("_ProductResults", Model)
        </section>
    </div>
</div>
