@model ProductListingViewModel

@{
    ViewData["Title"] = "Products";
}

@foreach (var block in Model.HeaderContent)
{
    @await Html.PartialAsync(block.PartialViewName, block)
}

<div class="container py-4">
    <div class="row">
        @foreach (var product in Model.Products)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    @if (product.MainImage != null)
                    {
                        <img src="@product.MainImage.Url" class="card-img-top" alt="@(product.MainImage.Description ?? product.Name)">
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        @if (!string.IsNullOrEmpty(product.Description))
                        {
                            <p class="card-text flex-grow-1">@product.Description</p>
                        }
                        @if (product.Price.HasValue)
                        {
                            <p class="card-text"><strong>@product.Price.Value.ToString("C")</strong></p>
                        }
                        <a asp-action="Details" asp-route-slug="@product.Slug" class="btn btn-primary mt-auto">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
