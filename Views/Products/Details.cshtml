@model Ficto.Models.ProductDetailViewModel

@{
    ViewData["Title"] = Model.Product.Name;
    var product = Model.Product;
}

<section class="product-hero" data-kontent-item-id="@product.ItemId">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6 product-hero__text">
                <a asp-action="Index" class="product-hero__back">&larr; Back to products</a>
                @if (!string.IsNullOrEmpty(product.Category))
                {
                    <div data-kontent-element-codename="category">
                        <span class="badge rounded-pill category-badge">@product.Category</span>
                    </div>
                }
                <h1 data-kontent-element-codename="product_base__name">@product.Name</h1>
                @if (product.Price.HasValue)
                {
                    <p class="product-hero__price" data-kontent-element-codename="price">@product.Price.Value.ToString("C")</p>
                }
                @if (!string.IsNullOrEmpty(product.Description))
                {
                    <p class="lead" data-kontent-element-codename="product_base__description">@product.Description</p>
                }
            </div>
            <div class="col-md-6 text-center">
                @if (product.MainImage != null)
                {
                    <img-asset asset="product.MainImage"
                               title="@(product.MainImage.Description ?? product.Name)"
                               class="product-hero__image"
                               default-width="900"
                               format="ImageFormat.Webp"
                               quality="85"
                               data-kontent-element-codename="product_base__main_image" />
                }
            </div>
        </div>
    </div>
</section>

<section class="related-products py-5">
    <h2 class="mb-4">Related products</h2>

    @if (Model.Related.Count == 0)
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <p class="mb-3 text-muted">No related products in this category yet.</p>
                <a asp-action="Index" class="btn btn-primary">Browse all products</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var related in Model.Related)
            {
                <div class="col-md-6 col-xl-3">
                    <div class="card h-100" data-kontent-item-id="@related.ItemId">
                        @if (related.MainImage != null)
                        {
                            <img-asset asset="related.MainImage"
                                       title="@(related.MainImage.Description ?? related.Name)"
                                       class="card-img-top product-card__image"
                                       default-width="400"
                                       format="ImageFormat.Webp"
                                       quality="80"
                                       data-kontent-element-codename="product_base__main_image" />
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title" data-kontent-element-codename="product_base__name">@related.Name</h5>
                            @if (related.Price.HasValue)
                            {
                                <p class="card-text" data-kontent-element-codename="price"><strong>@related.Price.Value.ToString("C")</strong></p>
                            }
                            <a asp-action="Details" asp-route-slug="@related.Slug" class="btn btn-primary mt-auto">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>
