@model ProductListingViewModel

@if (Model.SelectedCategories.Count > 0)
{
    <p class="text-muted small mb-3">
        Filtered by @Model.SelectedCategories.Count categor@(Model.SelectedCategories.Count == 1 ? "y" : "ies").
    </p>
}

@if (Model.Products.Count == 0)
{
    <div class="alert alert-light border">
        No products match the selected filters.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model.Products)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100" data-kontent-item-id="@product.ItemId">
                    @if (product.MainImage != null)
                    {
                        <img src="@product.MainImage.UrlWithTransform(width: 600, format: ImageFormat.Webp, quality: 80)"
                             class="card-img-top product-card__image"
                             alt="@(product.MainImage.AltText ?? product.Name)"
                             data-kontent-element-codename="product_base__main_image" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title" data-kontent-element-codename="product_base__name">@product.Name</h5>
                        @if (product.Price.HasValue)
                        {
                            <p class="card-text flex-grow-1" data-kontent-element-codename="price"><strong>@product.Price.Value.ToString("C")</strong></p>
                        }
                        <a asp-action="Details" asp-route-slug="@product.Slug" class="btn btn-primary mt-auto">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @await Html.PartialAsync("_Pager", Model.Pager)
}
