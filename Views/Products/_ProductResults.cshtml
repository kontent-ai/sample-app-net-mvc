@model ProductListingViewModel

@if (Model.SelectedCategories.Count > 0)
{
    <p class="text-muted small mb-3">
        Showing @Model.Products.Count product@(Model.Products.Count == 1 ? "" : "s")
        filtered by @Model.SelectedCategories.Count categor@(Model.SelectedCategories.Count == 1 ? "y" : "ies").
    </p>
}

@if (Model.Products.Count == 0)
{
    <div class="alert alert-light border">
        No products match the selected filters.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model.Products)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    @if (product.MainImage != null)
                    {
                        <img src="@product.MainImage.Url" class="card-img-top product-card__image" alt="@(product.MainImage.Description ?? product.Name)">
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        @if (product.Price.HasValue)
                        {
                            <p class="card-text flex-grow-1"><strong>@product.Price.Value.ToString("C")</strong></p>
                        }
                        <a asp-action="Details" asp-route-slug="@product.Slug" class="btn btn-primary mt-auto">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
