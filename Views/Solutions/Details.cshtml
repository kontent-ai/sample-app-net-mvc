@model Ficto.Models.SolutionViewModel

@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-4" data-kontent-item-id="@Model.ItemId">
    <h1 data-kontent-element-codename="product_base__name">@Model.Name</h1>

    @if (!string.IsNullOrEmpty(Model.ImagingTechnology))
    {
        <p class="text-muted" data-kontent-element-codename="imaging_technology">@Model.ImagingTechnology</p>
    }

    @if (Model.MainImage != null)
    {
        <img src="@Model.MainImage.UrlWithTransform(width: 1200, format: ImageFormat.Webp, quality: 85)"
             alt="@(Model.MainImage.AltText ?? Model.Name)"
             class="img-fluid mb-4"
             style="max-width: 600px;"
             data-kontent-element-codename="product_base__main_image" />
    }

    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p class="lead" data-kontent-element-codename="product_base__description">@Model.Description</p>
    }

    @if (!string.IsNullOrEmpty(Model.Showcase))
    {
        <div class="showcase mt-4" data-kontent-element-codename="showcase">
            @Html.Raw(Model.Showcase)
        </div>
    }
</div>
