@model FactViewModel

<div class="card h-100 fact-card" data-kontent-item-id="@Model.ItemId">
    @if (Model.Image != null)
    {
        <img-asset asset="Model.Image"
                   title="@(Model.Image.Description ?? Model.Title ?? "")"
                   class="card-img-top"
                   default-width="500"
                   format="ImageFormat.Webp"
                   quality="80"
                   data-kontent-element-codename="image" />
    }
    <div class="card-body d-flex flex-column">
        @if (!string.IsNullOrEmpty(Model.Title))
        {
            <h5 class="card-title" data-kontent-element-codename="title">@Model.Title</h5>
        }
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <p class="card-text flex-grow-1" data-kontent-element-codename="message">@Model.Message</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.LinkLabel))
        {
            <div class="mt-auto">
                @await Html.PartialAsync("_FactReference", Model)
            </div>
        }
    </div>
</div>
