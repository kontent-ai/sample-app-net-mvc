@model VisualContainerViewModel

@{
    var carouselId = $"hero-carousel-{Guid.NewGuid():N}";
    var hasMultipleItems = Model.Items.Count > 1;
}

<section class="visual-container visual-container--hero" data-kontent-item-id="@Model.ItemId">
    @if (hasMultipleItems)
    {
        <div id="@carouselId" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000" data-kontent-element-codename="items">
            <div class="carousel-indicators">
                @for (var i = 0; i < Model.Items.Count; i++)
                {
                    <button type="button"
                            data-bs-target="#@carouselId"
                            data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")"
                            aria-current="@(i == 0 ? "true" : "false")"
                            aria-label="Slide @(i + 1)"></button>
                }
            </div>
            <div class="carousel-inner">
                @for (var i = 0; i < Model.Items.Count; i++)
                {
                    var fact = Model.Items[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")" data-kontent-item-id="@fact.ItemId">
                        <div class="hero-slide" style="background-image: url('@(fact.Image?.UrlWithTransform(width: 1600, format: ImageFormat.Webp, quality: 85) ?? "")');">
                            <div class="container">
                                <div class="hero-content">
                                    @if (!string.IsNullOrEmpty(fact.Title))
                                    {
                                        <h1 class="hero-title" data-kontent-element-codename="title">@fact.Title</h1>
                                    }
                                    @if (!string.IsNullOrEmpty(fact.Message))
                                    {
                                        <p class="hero-message" data-kontent-element-codename="message">@fact.Message</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(fact.LinkLabel))
                                    {
                                        @await Html.PartialAsync("_FactReference", fact)
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    }
    else if (Model.Items.Count == 1)
    {
        var fact = Model.Items[0];
        <div class="hero-slide" style="background-image: url('@(fact.Image?.UrlWithTransform(width: 1600, format: ImageFormat.Webp, quality: 85) ?? "")');" data-kontent-item-id="@fact.ItemId">
            <div class="container">
                <div class="hero-content">
                    @if (!string.IsNullOrEmpty(fact.Title))
                    {
                        <h1 class="hero-title" data-kontent-element-codename="title">@fact.Title</h1>
                    }
                    @if (!string.IsNullOrEmpty(fact.Message))
                    {
                        <p class="hero-message" data-kontent-element-codename="message">@fact.Message</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(fact.LinkLabel))
                    {
                        @await Html.PartialAsync("_FactReference", fact)
                    }
                </div>
            </div>
        </div>
    }
</section>
