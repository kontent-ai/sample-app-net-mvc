@inject Ficto.Services.Content.IPreviewContext PreviewContext
@inject Ficto.Services.Content.ISpaceContext SpaceContext
@{
    var subsiteName = SpaceContext.SpaceCodename switch
    {
        "ficto_imaging" => "Imaging",
        "ficto_healthtech" => "Healthtech",
        "ficto_surgical" => "Surgical",
        _ => ""
    };
    var brandTitle = string.IsNullOrEmpty(subsiteName) ? "Ficto" : $"Ficto | {subsiteName}";
    var pageTitle = ViewData["Title"]?.ToString();
    var fullTitle = string.IsNullOrWhiteSpace(pageTitle) ? brandTitle : $"{pageTitle} - {brandTitle}";
}
<!DOCTYPE html>
<html lang="en" data-theme="@SpaceContext.SpaceCodename">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@fullTitle</title>
    <script type="importmap"></script>
    <link rel="icon" type="image/png" href="~/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ficto.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/logo.png" alt="" height="32" class="brand-logo" />
                    <span class="brand-name">Ficto</span>
                    @if (!string.IsNullOrEmpty(subsiteName))
                    {
                        <span class="brand-sep" aria-hidden="true">|</span>
                        <span class="brand-site">@subsiteName</span>
                    }
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav ms-auto">
                        @await Component.InvokeAsync("Navigation")
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @if (PreviewContext.IsPreview)
    {
        <div class="alert alert-success mb-0 rounded-0 text-center py-2" role="alert">
            Preview mode &mdash; showing unpublished draft content &middot;
            <a asp-controller="Preview" asp-action="Disable" asp-route-returnUrl="@Context.Request.Path">Disable</a>
        </div>
    }
    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container text-center">
            &copy; 2026 - <a href="https://kontent.ai" target="_blank" rel="noopener">Kontent.ai</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
