@inject Ficto.Services.Content.IPreviewContext PreviewContext
@inject Ficto.Services.Content.ISpaceContext SpaceContext
@inject IConfiguration Configuration
@{
    var environmentId = Configuration["DeliveryOptions:EnvironmentId"] ?? string.Empty;
    var subsiteName = SpaceContext.SpaceCodename switch
    {
        "ficto_imaging" => "Imaging",
        "ficto_healthtech" => "Healthtech",
        "ficto_surgical" => "Surgical",
        _ => ""
    };
    var brandTitle = string.IsNullOrEmpty(subsiteName) ? "Ficto" : $"Ficto | {subsiteName}";
    var pageTitle = ViewData["Title"]?.ToString();
    var fullTitle = string.IsNullOrWhiteSpace(pageTitle) ? brandTitle : $"{pageTitle} - {brandTitle}";
}
<!DOCTYPE html>
<html lang="en" data-theme="@SpaceContext.SpaceCodename">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@fullTitle</title>
    <script type="importmap"></script>
    <link rel="icon" type="image/png" href="~/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ficto.styles.css" asp-append-version="true" />
    @if (PreviewContext.IsPreview)
    {
        await Html.RenderPartialAsync("_SmartLinkScript");
    }
</head>
<body class="d-flex flex-column min-vh-100"
      data-kontent-environment-id="@environmentId"
      data-kontent-language-codename="default">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/logo.png" alt="" height="32" class="brand-logo" />
                    <span class="brand-name">Ficto</span>
                    @if (!string.IsNullOrEmpty(subsiteName))
                    {
                        <span class="brand-sep" aria-hidden="true">|</span>
                        <span class="brand-site">@subsiteName</span>
                    }
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav ms-auto">
                        @await Component.InvokeAsync("Navigation")
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @if (PreviewContext.IsPreview)
    {
        <aside class="preview-banner" data-preview-banner role="status" aria-label="Preview mode">
            <button type="button" class="preview-banner__toggle" data-preview-toggle
                    aria-expanded="true" aria-controls="preview-banner-body" title="Toggle preview panel">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                    <path fill="currentColor" d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                    <path fill="currentColor" d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                </svg>
                <span class="visually-hidden">Toggle preview panel</span>
            </button>
            <div class="preview-banner__body" id="preview-banner-body">
                <span class="preview-banner__label">Preview mode</span>
                <a class="preview-banner__action" asp-controller="Preview" asp-action="Disable" asp-route-returnUrl="@Context.Request.Path">Disable</a>
            </div>
        </aside>
    }
    <main role="main" class="container flex-grow-1">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container text-center">
            &copy; 2026 - <a href="https://kontent.ai" target="_blank" rel="noopener">Kontent.ai</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
