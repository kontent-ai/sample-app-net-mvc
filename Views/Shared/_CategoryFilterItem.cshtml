@model Ficto.Models.CategoryTermViewModel

<li class="product-filter__item">
    <div class="form-check">
        <input class="form-check-input"
               type="checkbox"
               name="category"
               value="@Model.Codename"
               id="category-@Model.Codename"
               @(Model.IsSelected ? "checked" : null) />
        <label class="form-check-label" for="category-@Model.Codename">
            @Model.Name
        </label>
    </div>
    @if (Model.Children.Count > 0)
    {
        <ul class="list-unstyled product-filter__children">
            @foreach (var child in Model.Children)
            {
                @await Html.PartialAsync("_CategoryFilterItem", child)
            }
        </ul>
    }
</li>
