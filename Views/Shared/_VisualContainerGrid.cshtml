@model VisualContainerViewModel

<section class="visual-container visual-container--grid py-5" data-kontent-item-id="@Model.ItemId">
    <div class="container">
        @if (!string.IsNullOrEmpty(Model.Title))
        {
            <h2 class="mb-3" data-kontent-element-codename="title">@Model.Title</h2>
        }
        @if (!string.IsNullOrEmpty(Model.Subtitle))
        {
            <p class="text-muted mb-4" data-kontent-element-codename="subtitle">@Model.Subtitle</p>
        }
        <div class="row g-4" data-kontent-element-codename="items">
            @foreach (var fact in Model.Items)
            {
                <div class="col-md-6 col-lg-4">
                    @await Html.PartialAsync("_FactCard", fact)
                </div>
            }
        </div>
    </div>
</section>
