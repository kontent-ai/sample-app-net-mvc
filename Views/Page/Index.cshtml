@model PageViewModel

@{
    ViewData["Title"] = !string.IsNullOrWhiteSpace(Model.MetadataTitle) ? Model.MetadataTitle
                      : !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title
                      : "Page";
}

@foreach (var block in Model.Content)
{
    @await Html.PartialAsync(block.PartialViewName, block)
}
